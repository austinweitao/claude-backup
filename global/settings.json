{
  "env": {
    "ANTHROPIC_BASE_URL": "https://rsxermu666.cn",
    "ANTHROPIC_AUTH_TOKEN": "sk-VRxIQK4HsrcyF3zbGm38t5fqugeusKuulDxme2NnxJ1y9TcG",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "ANTHROPIC_MODEL": "claude-fable-5",
    "ANTHROPIC_SMALL_FAST_MODEL": "claude-sonnet-4.6",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4.6",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4.8",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4.5"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "WebFetch(*)",
      "WebSearch(*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -f /*)",
      "Bash(sudo rm *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(dd if=*)",
      "Bash(mkfs*)",
      "Bash(fdisk*)"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/cwtrocks/.claude/hooks/session-start-inject.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/cwtrocks/.claude/hooks/user-prompt-turn-sentinel.sh"
          },
          {
            "type": "command",
            "command": "echo '\\n⚠️ [协议] 4 引擎搜索必须实际调用后才标注；字段/函数/常量必须实测；每篇必有硬性事实清单。如不能 100% 保证，请在回答开头明确声明 [本回答不保证遵守 Android 协议，原因：xxx]。宁可不答，不可敷衍。\\n'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/cwtrocks/.claude/hooks/pre-tool-use-search-gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/cwtrocks/.claude/hooks/post-tool-use-audit.sh"
          },
          {
            "type": "command",
            "command": "/home/cwtrocks/.claude/hooks/mermaid-auto-render.sh",
            "timeout": 120000
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "claude-mem@thedotmack": true
  },
  "skipWebFetchPreflight": true,
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true
}
